// thanks to this, the command 'gradle run' will launch the launcher,
application {
    //mainClass = "klik.Launcher"
    mainClass = "klik.Klik_application"

}

compileJava {
    options.compilerArgs.add('--enable-preview')
}

run{
    standardInput = System.in
    classpath = sourceSets.main.runtimeClasspath
    jvmArgs = ['--enable-preview']
}

shadowJar {
    archiveFileName.set("klik.jar")
    manifest {
        attributes(
                'Main-Class': 'klik.Klik_application',
                'JavaFX-Modules': ['javafx.base','javafx.graphics','javafx.controls','javafx.fxml','javafx.swing','javafx.media', 'javafx.web']
        )
    }
    mergeServiceFiles()
}

graalvmNative {
    binaries.all {
        resources.autodetect()
    }
}

